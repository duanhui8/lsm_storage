{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch observer (CLI mode)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/bin/observer",
            "args": [
                "-P", "cli",
                "-E", "ob"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Disable pagination for faster stepping",
                    "text": "set pagination off",
                    "ignoreFailures": true
                },
                {
                    "description": "Limit print elements to avoid huge string dumps",
                    "text": "set print elements 200",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch observer (TCP mode)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/bin/observer",
            "args": [
                "-f", "etc/observer.ini",
                "-p", "6789",
                "-E", "lsm",
                "-t", "lsm"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Disable pagination for faster stepping",
                    "text": "set pagination off",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch current unittest",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/unittest/${relativeFileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Attach to observer",
            "type": "cppdbg",
            "request": "attach",
            "program": "${workspaceFolder}/build_debug/bin/observer",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
